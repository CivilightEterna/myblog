# ===========================================
# Blog Admin API — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git!

# --- Server ---
SERVER_PORT=8080
# Set to "release" for production
GIN_MODE=debug

# --- Database ---
# Absolute or relative path to SQLite database file
DB_PATH=./data/blog_admin.db

# --- Security (CRITICAL for production) ---
# JWT signing secret — use a long random string
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string

# Initial admin account (only used on first run when DB is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- CORS ---
# Comma-separated list of allowed origins
# Dev: http://localhost:5173
# Prod: https://your-domain.com
CORS_ORIGIN=http://localhost:5173,http://localhost:4321

# --- Paths ---
# Root directory of the blog monorepo (absolute path)
# Default: auto-detected (two levels up from admin-api)
# BLOG_ROOT=/opt/blog

# --- Production ---
# Set to "true" to enable production security checks
# PRODUCTION=false
