---
import PageLayout from "@layouts/PageLayout.astro";
import SearchBoxIsland from "@components/SearchBoxIsland.vue";

const title = "搜索";
const description = "搜索博客中的文章";
---

<PageLayout title={title} description={description}>
  <div class="search-page">
    <h1 class="search-title">{title}</h1>
    <SearchBoxIsland client:load />
  </div>
</PageLayout>

<style>
  .search-page {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .search-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: var(--color-text);
    text-align: center;
  }
</style>
