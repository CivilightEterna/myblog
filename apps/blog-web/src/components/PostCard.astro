---
import PostMeta from "./PostMeta.astro";
import TagList from "./TagList.astro";

export interface Props {
  title: string;
  slug: string;
  description: string;
  date: string;
  updated?: string;
  category: string;
  tags: string[];
  cover?: string;
  pinned?: boolean;
}

const { title, slug, description, date, updated, category, tags, cover, pinned } = Astro.props;
---

<article class={`post-card ${pinned ? "post-card--pinned" : ""}`}>
  {cover && (
    <a href={`/posts/${slug}`} class="post-card-cover">
      <img src={cover} alt={title} loading="lazy" />
    </a>
  )}

  <div class="post-card-body">
    <div class="post-card-header">
      {pinned && <span class="pinned-badge">置顶</span>}
      <a href={`/categories/${category}`} class="category-label">{category}</a>
    </div>

    <h2 class="post-card-title">
      <a href={`/posts/${slug}`}>{title}</a>
    </h2>

    <p class="post-card-desc">{description}</p>

    <PostMeta date={date} updated={updated} category={undefined} tags={undefined} />

    {tags.length > 0 && (
      <div class="post-card-tags">
        <TagList tags={tags} />
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-card);
  }

  .post-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .post-card--pinned {
    border-color: var(--color-primary);
  }

  .post-card-cover {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .post-card:hover .post-card-cover img {
    transform: scale(1.05);
  }

  .post-card-body {
    padding: 1.5rem;
  }

  .post-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .pinned-badge {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    background: var(--color-primary);
    border-radius: var(--radius-sm);
  }

  .category-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-primary);
    padding: 0.125rem 0.5rem;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border-radius: var(--radius-sm);
  }

  .post-card-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .post-card-title a {
    color: var(--color-text);
  }

  .post-card-title a:hover {
    color: var(--color-primary);
  }

  .post-card-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-tags {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
</style>
