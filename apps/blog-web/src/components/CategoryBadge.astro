---
export interface Props {
  category: string;
  href?: string;
}

const { category, href } = Astro.props;
const Tag = href ? "a" : "span";
---

<Tag href={href || undefined} class="category-badge">
  <span class="category-icon">📁</span>
  {category}
</Tag>

<style>
  .category-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  a.category-badge:hover {
    background: var(--color-primary);
    color: #fff;
  }

  .category-icon {
    font-size: 0.75rem;
  }
</style>
