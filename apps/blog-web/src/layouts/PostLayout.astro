---
import BaseLayout from "./BaseLayout.astro";
import PostMeta from "@components/PostMeta.astro";
import TagList from "@components/TagList.astro";
import Toc from "@components/Toc.astro";
import Pagination from "@components/Pagination.astro";
import type { CollectionEntry } from "astro:content";
import type { Heading } from "@components/Toc.astro";

export interface Props {
  post: CollectionEntry<"posts">;
  prev: CollectionEntry<"posts"> | null;
  next: CollectionEntry<"posts"> | null;
  headings?: Heading[];
}

const { post, prev, next, headings = [] } = Astro.props;
const { data, body } = post;
const { title, description, date, updated, category, tags, cover, toc } = data;
const showToc = toc && headings.length > 0;

// Format prev/next for Pagination component
const prevLink = prev ? { title: prev.data.title, slug: prev.slug } : null;
const nextLink = next ? { title: next.data.title, slug: next.slug } : null;
---

<BaseLayout title={title} description={description} ogImage={cover || undefined}>
  <article class="post-article">
    <header class="post-header">
      {category && (
        <a href={`/categories/${category}`} class="post-category">{category}</a>
      )}

      <h1 class="post-title">{title}</h1>

      <PostMeta
        date={date}
        updated={updated}
        category={undefined}
        tags={undefined}
      />

      {tags.length > 0 && (
        <div class="post-tags">
          <TagList tags={tags} />
        </div>
      )}

      {cover && (
        <div class="post-cover">
          <img src={cover} alt={title} />
        </div>
      )}
    </header>

    <div class="post-body-wrapper">
      {showToc && (
        <aside class="post-sidebar">
          <div class="post-toc-sticky">
            <Toc headings={headings} />
          </div>
        </aside>
      )}

      <div class={`post-content ${showToc ? "post-content--with-sidebar" : ""}`}>
        <div class="markdown-body">
          {body}
        </div>
      </div>
    </div>

    <footer class="post-footer">
      <Pagination prev={prevLink} next={nextLink} />
    </footer>
  </article>
</BaseLayout>

<style>
  .post-article {
    max-width: 100%;
  }

  .post-header {
    text-align: center;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-category {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .post-title {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .post-tags {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .post-cover {
    margin-top: 2rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .post-cover img {
    width: 100%;
    display: block;
  }

  .post-body-wrapper {
    display: flex;
    gap: 2rem;
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .post-sidebar {
    width: 240px;
    flex-shrink: 0;
  }

  .post-toc-sticky {
    position: sticky;
    top: 80px;
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-content--with-sidebar {
    max-width: var(--max-width-content);
  }

  .post-footer {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (max-width: 1024px) {
    .post-body-wrapper {
      flex-direction: column;
      padding: 0 1.5rem;
    }

    .post-sidebar {
      width: 100%;
      order: -1;
    }

    .post-toc-sticky {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.625rem;
    }
  }
</style>
