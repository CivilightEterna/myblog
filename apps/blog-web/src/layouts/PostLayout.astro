---
import BaseLayout from "./BaseLayout.astro";
import FeatureHost from "@features/FeatureHost.astro";
import PostMeta from "@components/PostMeta.astro";
import TagList from "@components/TagList.astro";
import PostToc from "@components/PostToc.vue";
import Pagination from "@components/Pagination.astro";
import CommentSection from "@components/CommentSection.vue";
import type { CollectionEntry } from "astro:content";

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  post: CollectionEntry<"posts">;
  prev: CollectionEntry<"posts"> | null;
  next: CollectionEntry<"posts"> | null;
  headings?: Heading[];
}

const { post, prev, next, headings = [] } = Astro.props;
const { data } = post;
const { title, description, date, updated, category, tags, cover, toc, aiSummary } = data;
const showToc = toc && headings.length > 0;

// Format prev/next for Pagination component
const prevLink = prev ? { title: prev.data.title, slug: prev.slug } : null;
const nextLink = next ? { title: next.data.title, slug: next.slug } : null;
---

<BaseLayout title={title} description={description} ogImage={cover || undefined}>
  <article class="post-article">
    <header class="post-header">
      {category && (
        <a href={`/categories/${category}`} class="post-category">{category}</a>
      )}

      <h1 class="post-title">{title}</h1>

      <PostMeta
        date={date}
        updated={updated}
        category={undefined}
        tags={undefined}
      />

      {tags.length > 0 && (
        <div class="post-tags">
          <TagList tags={tags} />
        </div>
      )}

      {cover && (
        <div class="post-cover">
          <img src={cover} alt={title} />
        </div>
      )}
    </header>

    {aiSummary && (
      <div class="ai-summary-card">
        <span class="ai-summary-label">AI 摘要</span>
        <p class="ai-summary-text">{aiSummary}</p>
      </div>
    )}

    <div class="post-body-wrapper">
      {showToc && (
        <aside class="post-sidebar">
          <div class="post-toc-sticky">
            <PostToc headings={headings} client:load />
          </div>
        </aside>
      )}

      <div class={`post-content ${showToc ? "post-content--with-sidebar" : ""}`}>
        <div class="markdown-body">
          <slot />
        </div>
      </div>
    </div>

    <footer class="post-footer">
      <Pagination prev={prevLink} next={nextLink} />

      <!-- Comments -->
      <div class="post-comments">
        <CommentSection client:visible />
      </div>

      <!-- Feature: post-after-content -->
      <FeatureHost position="post-after-content" />
    </footer>
  </article>
</BaseLayout>

<style>
  .post-article {
    max-width: 100%;
  }

  .post-header {
    text-align: center;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-category {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .post-title {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .post-tags {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .post-cover {
    margin-top: 2rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .post-cover img {
    width: 100%;
    display: block;
  }

  .post-body-wrapper {
    display: flex;
    gap: 2rem;
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .post-sidebar {
    width: 240px;
    flex-shrink: 0;
  }

  .post-toc-sticky {
    position: sticky;
    top: 80px;
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-content--with-sidebar {
    max-width: var(--max-width-content);
  }

  .ai-summary-card {
    max-width: var(--max-width-content);
    margin: 0 auto 2rem;
    padding: 1rem 1.5rem;
    background: color-mix(in srgb, var(--color-primary) 8%, var(--color-bg));
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, var(--color-border));
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-primary);
  }

  .ai-summary-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .ai-summary-text {
    font-size: 0.9375rem;
    line-height: 1.85;
    color: var(--color-text);
    margin: 0;
  }

  .post-comments {
    max-width: var(--max-width-content);
    margin: 2rem auto 0;
    padding: 0 1.5rem;
  }

  .post-footer {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (max-width: 1024px) {
    .post-body-wrapper {
      flex-direction: column;
      padding: 0 1.5rem;
    }

    .post-sidebar {
      width: 100%;
      order: -1;
    }

    .post-toc-sticky {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.625rem;
    }
  }
</style>

<!-- Post layout variants — global scope (targets <html data-post-layout>) -->
<style is:global>
  /* ===== TOC Collapsed: hide sidebar, expand content ===== */
  [data-toc-collapsed] .post-sidebar {
    width: 0;
    padding: 0;
    overflow: visible;
  }
  [data-toc-collapsed] .post-content--with-sidebar {
    max-width: calc(var(--max-width-content) + 180px);
  }
  /* Don't collapse in wide layout */
  [data-post-layout="wide"] .post-sidebar {
    width: 100% !important;
  }

  /* ===== CLEAN Layout (no sidebar, centered) ===== */
  [data-post-layout="clean"] .post-body-wrapper {
    flex-direction: column;
    padding: 0 1.5rem;
  }
  [data-post-layout="clean"] .post-sidebar {
    display: none;
  }
  [data-post-layout="clean"] .post-content {
    max-width: var(--max-width-content);
  }
  [data-post-layout="clean"] .post-content--with-sidebar {
    max-width: var(--max-width-content);
  }

  /* ===== WIDE Layout (full width, TOC at top as horizontal nav) ===== */
  [data-post-layout="wide"] .post-body-wrapper {
    flex-direction: column;
    padding: 0;
  }
  [data-post-layout="wide"] .post-sidebar {
    width: 100%;
    order: 0;
    margin-bottom: 1.5rem;
  }
  [data-post-layout="wide"] .post-toc-sticky {
    position: static;
  }
  [data-post-layout="wide"] .toc {
    margin-bottom: 0;
  }
  [data-post-layout="wide"] .toc-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
  }
  [data-post-layout="wide"] .toc-item {
    margin-bottom: 0;
    padding-left: 0 !important;
  }
  [data-post-layout="wide"] .toc-link {
    border-left: none;
  }
  [data-post-layout="wide"] .post-content {
    max-width: 100%;
  }
  [data-post-layout="wide"] .post-content--with-sidebar {
    max-width: 100%;
  }
  [data-post-layout="wide"] .post-body-wrapper {
    max-width: 100%;
    padding: 0 1.5rem;
  }
  [data-post-layout="wide"] .post-footer {
    max-width: 100%;
  }
</style>
