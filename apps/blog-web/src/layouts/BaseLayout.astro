---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import FeatureHost from "@features/FeatureHost.astro";
import ReadingProgress from "@components/ReadingProgress.vue";
import { siteConfig } from "@config/site.config";
import "@/styles/global.css";
import "@/styles/markdown.css";
import fs from "node:fs";
import path from "node:path";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const pageTitle = title ? `${title} — ${siteConfig.title}` : siteConfig.title;
const pageDesc = description || siteConfig.description;

// Read background settings from build-time generated config
let bgImage = "";
let bgOpacity = "0.18";
let bgMode = "cover";
let bgEnabled = false;

try {
  const configPath = path.join(process.cwd(), "public", "data", "site-config.json");
  if (fs.existsSync(configPath)) {
    const raw = fs.readFileSync(configPath, "utf-8");
    const cfg = JSON.parse(raw);
    if (cfg.site_background_enabled === "true" && cfg.site_background_image) {
      bgEnabled = true;
      bgImage = cfg.site_background_image;
      bgOpacity = cfg.site_background_opacity || "0.18";
      bgMode = cfg.site_background_mode || "cover";
    }
  }
} catch (_) {
  // No config yet — use defaults
}
---

<!DOCTYPE html>
<html lang={siteConfig.lang} data-home-layout="classic" data-post-layout="sidebar">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="author" content={siteConfig.author} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content={Astro.props.title ? "article" : "website"} />
    <meta property="og:url" content={new URL(Astro.url.pathname, siteConfig.url).href} />
    <meta property="og:site_name" content={siteConfig.title} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={siteConfig.title} href="/rss.xml" />

    <title>{pageTitle}</title>

    <!-- Theme init — prevent flash of wrong theme before page renders -->
    <script is:inline>
      (function() {
        const presets = {
          default:  { theme: "default",  homeLayout: "classic",  postLayout: "sidebar" },
          minimal:  { theme: "minimal",  homeLayout: "minimal",  postLayout: "clean" },
          dark:     { theme: "dark",     homeLayout: "classic",  postLayout: "sidebar" },
          terminal: { theme: "terminal", homeLayout: "terminal", postLayout: "clean" },
        };
        const key = localStorage.getItem("activeTheme") || "default";
        const p = presets[key] || presets.default;
        document.documentElement.setAttribute("data-theme", p.theme);
        document.documentElement.setAttribute("data-home-layout", p.homeLayout);
        document.documentElement.setAttribute("data-post-layout", p.postLayout);
      })();
    </script>
      <!-- Dynamic background config — runtime fetch from API, no rebuild needed -->
    <script is:inline>
      (async function() {
        try {
          const resp = await fetch('/api/public/site-config');
          if (!resp.ok) throw new Error('API not available');
          const cfg = await resp.json();

          const root = document.documentElement;
          if (cfg.site_background_enabled === 'true' && cfg.site_background_image) {
            root.style.setProperty('--site-background-image', `url(${cfg.site_background_image})`);
            root.style.setProperty('--site-background-opacity', cfg.site_background_opacity || '0.18');
            root.style.setProperty('--site-background-size', cfg.site_background_mode || 'cover');
            root.style.setProperty('--site-background-position', cfg.site_background_position || 'center');
            root.setAttribute('data-background-enabled', 'true');
          } else {
            root.removeAttribute('data-background-enabled');
          }
        } catch (e) {
          // API unavailable — fall back to static site-config.json or build-time values
          console.log('Dynamic config not available, using static fallback');
        }
      })();
    </script>
  </head>

  <body>
    <ReadingProgress client:load />
    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Feature: global-floating (pet, music player, etc.) -->
    <FeatureHost position="global-floating" />

    <!-- Back to top -->
    <button id="back-to-top" class="back-to-top hidden" aria-label="回到顶部" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="19" x2="12" y2="5"/>
        <polyline points="5 12 12 5 19 12"/>
      </svg>
    </button>
  </body>
</html>

<style is:global>
  /* Site background layer — controlled by CSS variables set at runtime */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image: var(--site-background-image, none);
    background-size: var(--site-background-size, cover);
    background-position: var(--site-background-position, center);
    background-repeat: no-repeat;
    opacity: var(--site-background-opacity, 0.18);
    pointer-events: none;
  }

  /* Hide pseudo-element when no background is set */
  html:not([data-background-enabled]) body::before {
    display: none;
  }

  /* Dark theme overlay for readability */
  [data-theme="dark"][data-background-enabled] body::before,
  [data-theme="terminal"][data-background-enabled] body::before {
    filter: brightness(0.4);
  }

  /* Ensure content cards remain readable over background */
  [data-home-layout="classic"][data-background-enabled] .post-card,
  [data-home-layout="magazine"][data-background-enabled] .post-card {
    backdrop-filter: blur(2px);
  }
</style>

<style>
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-card);
    transition: all 0.3s ease;
    z-index: 50;
  }

  .back-to-top:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .back-to-top.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px);
  }
</style>

<script>
  function initBackToTop() {
    const btn = document.getElementById("back-to-top");
    if (!btn) return;

    window.addEventListener("scroll", () => {
      if (window.scrollY > 400) {
        btn.classList.remove("hidden");
      } else {
        btn.classList.add("hidden");
      }
    });

    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  initBackToTop();
  document.addEventListener("astro:after-swap", initBackToTop);
</script>
