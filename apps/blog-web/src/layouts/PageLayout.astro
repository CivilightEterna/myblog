---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="container-wide page-content">
    <slot />
  </div>
</BaseLayout>

<style>
  .page-content {
    padding-top: 2rem;
    padding-bottom: 2rem;
    min-height: 60vh;
  }
</style>
